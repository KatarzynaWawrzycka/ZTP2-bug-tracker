{% extends 'base.html.twig' %}

{% block title %}
    {{ 'title.bug_list'|trans }}
{% endblock %}

{% block body %}
    <h1>{{ 'title.bug_list'|trans }}</h1>
    {% if bugs is defined and bugs|length %}
        <table class="table table-striped">
            <thead>
            <tr>
                <th>{{ 'label.id'|trans }}</th>
                <th>{{ 'label.created_at'|trans }}</th>
                <th>{{ 'label.updated_at'|trans }}</th>
                <th>{{ 'label.title'|trans }}</th>
                <th>{{ 'label.description'|trans }}</th>
                <th>{{ 'label.actions'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for bug in bugs %}
                <tr>
                    <td>{{ bug.id }}</td>
                    <td>{{ bug.createdAt|date('Y/m/d') }}</td>
                    <td>{{ bug.updatedAt|date('Y/m/d') }}</td>
                    <td>{{ bug.title }}</td>
                    <td>{{ bug.description }}</td>
                    <td>
                        <a href="{{ url('bug_view', {id: bug.id}) }}" title="{{ 'action.view'|trans }}">
                            {{ 'action.view'|trans }}
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>
            {{ 'message.empty_list'|trans }}
        </p>
    {% endif %}
{% endblock %}
